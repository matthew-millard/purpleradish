    "drizzle-orm": "^0.45.2",
    "isbot": "^5.1.36",
    "postgres": "^3.4.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "8.1.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.4",
    "@react-router/dev": "8.1.0",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "typescript": "^5.9.3",
